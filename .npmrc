; GitHub Packages auth for @decoperations scope.
; ${NODE_AUTH_TOKEN} is resolved at install time:
;   - CI: set via actions/setup-node + NODE_AUTH_TOKEN env
;   - Local: export NODE_AUTH_TOKEN=<PAT with read:packages>
; See docs/github-packages.md for setup details.
@decoperations:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
