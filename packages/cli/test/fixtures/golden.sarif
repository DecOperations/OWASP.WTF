    {
      "tool": {
        "driver": {
          "name": "owasp-wtf",
          "informationUri": "https://owasp.wtf",
          "version": "2.0.0",
          "rules": [
            {
              "id": "native:A03-SQL-INJECTION",
              "name": "SQL Injection",
              "shortDescription": {
                "text": "SQL Injection"
              },
              "fullDescription": {
                "text": "SQL query uses template literal interpolation, which is vulnerable to injection."
              },
              "helpUri": "https://owasp.org/Top10/"
            },
            {
              "id": "native:A03-COMMAND-INJECTION",
              "name": "Command Injection",
              "shortDescription": {
                "text": "Command Injection"
              },
              "fullDescription": {
                "text": "exec() with template literal interpolation. Unsanitized input in command execution enables OS command injection."
              },
              "helpUri": "https://owasp.org/Top10/"
            },
            {
              "id": "native:A03-EVAL",
              "name": "Dangerous eval() Usage",
              "shortDescription": {
                "text": "Dangerous eval() Usage"
              },
              "fullDescription": {
                "text": "eval() executes arbitrary code. If any input is user-controlled, this enables code injection."
              },
              "helpUri": "https://owasp.org/Top10/"
            },
            {
              "id": "native:A03-XSS",
              "name": "Cross-Site Scripting (XSS)",
              "shortDescription": {
                "text": "Cross-Site Scripting (XSS)"
              },
              "fullDescription": {
                "text": "Direct innerHTML assignment can execute injected scripts."
              },
              "helpUri": "https://owasp.org/Top10/"
            },
            {
              "id": "native:A03-PATH-TRAVERSAL",
              "name": "Path Traversal",
              "shortDescription": {
                "text": "Path Traversal"
              },
              "fullDescription": {
                "text": "User-supplied input used in file path without visible sanitization. May allow path traversal (../)."
              },
              "helpUri": "https://owasp.org/Top10/"
            },
            {
              "id": "native:A01-IDOR",
              "name": "Potential IDOR",
              "shortDescription": {
                "text": "Potential IDOR"
              },
              "fullDescription": {
                "text": "Database record accessed directly using user-supplied ID without visible ownership validation."
              },
              "helpUri": "https://owasp.org/Top10/"
            }
          ]
        }
      },
